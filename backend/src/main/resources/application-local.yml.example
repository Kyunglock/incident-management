## 로컬 전용 설정 템플릿.
## 이 파일을 application-local.yml 로 복사한 뒤 각자 환경에 맞게 수정하세요.
## application-local.yml 은 git 에 추적되지 않습니다 (충돌 방지).

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/incident_db
    username: postgres
    password: password
    driver-class-name: org.postgresql.Driver

ai:
  llm:
    # chat 엔드포인트 전체 URL (경로 포함). MLX 기반(OpenAI 호환) 서버.
    url: https://kwaklabs.com/api/v1/kwakai/chat
    # MLX 서버의 모델 식별자. 서버에 등록된 정확한 이름으로 맞춰야 한다.
    model: gemma4-31b

# git 연동 설정 (커밋 매핑용).
git:
  provider: ${GIT_PROVIDER:local}   # local(git CLI) | gitlab(REST API)

  # [local 모드] 시스템별 로컬 저장소 경로
  default-repo: ${GIT_DEFAULT_REPO:.}
  repositories: {}
    # member: /repos/member-service
    # payment: /repos/payment-service

  # [gitlab 모드] GitLab REST API 연동
  gitlab:
    base-url: ${GITLAB_BASE_URL:https://git.fusionsoft.co.kr}
    token: ${GITLAB_TOKEN:}          # Personal/Project Access Token (read_api 권한)
    branch: ${GITLAB_BRANCH:main}
    systems:                         # system 키 → 프로젝트 경로 목록 (1:N)
      # 에듀넷:
      #   - root/cnedu-front-edunet
      #   - root/cnedu-back-edunet
